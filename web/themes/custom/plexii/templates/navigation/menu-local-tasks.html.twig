{#
/**
 * @file
 * Theme override to display primary and secondary local tasks.
 *
 * Available variables:
 * - primary: HTML list items representing primary tasks.
 * - secondary: HTML list items representing secondary tasks.
 *
 * Each item in these variables (primary and secondary) can be individually
 * themed in menu-local-task.html.twig.
 */
#}
{% if primary %}
  <h2 class="visually-hidden">{{ 'Primary tabs'|t }}</h2>
  <nav class="local-tasks article-inner" aria-label="{{ 'Primary tabs'|t }}">
    <ul class="local-tasks__list">
      {{ primary }}
    </ul>
  </nav>
{% endif %}
{% if secondary %}
  <h2 class="visually-hidden">{{ 'Secondary tabs'|t }}</h2>
  <nav class="local-tasks local-tasks--secondary" aria-label="{{ 'Secondary tabs'|t }}">
    <ul class="local-tasks__list">
      {{ secondary }}
    </ul>
  </nav>
{% endif %}
